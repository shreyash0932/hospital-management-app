@model HospitalManagement.Models.Patient

<h2>Patient Details</h2>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>

    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>

    <tr>
        <th>Age</th>
        <td>@Model.Age</td>
    </tr>

    <tr>
        <th>Gender</th>
        <td>@Model.Gender</td>
    </tr>

    <tr>
        <th>Disease</th>
        <td>@Model.Disease</td>
    </tr>

    <tr>
        <th>Doctor Name</th>
        <td>@Model.DoctorName</td>
    </tr>

    <tr>
        <th>City</th>
        <td>@Model.City</td>
    </tr>
</table>

<a asp-action="Index" class="btn btn-primary">
  Back To Dashbord
</a>
@model IEnumerable<HospitalManagement.Models.Patient>

<h2>Patient List</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Age</th>
            <th>Gender</th>
            <th>Disease</th>
            <th>Doctor</th>
            <th>City</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Age</td>
                <td>@item.Gender</td>
                <td>@item.Disease</td>
                <td>@item.DoctorName</td>
                <td>@item.City</td>
            </tr>
        }
    </tbody>
</table>

@model HospitalManagement.Models.Patient

<h2>Edit Patient</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Age</label>
        <input asp-for="Age" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Gender</label>

        <select asp-for="Gender" class="form-control">
            <option>Male</option>
            <option>Female</option>
            <option>Other</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Disease</label>
        <input asp-for="Disease" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Doctor Name</label>
        <input asp-for="DoctorName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>City</label>
        <input asp-for="City" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning">
        Update
    </button>
  
    </form>
    <br />
    <br />
